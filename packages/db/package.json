{
  "name": "@open-query/db",
  "version": "0.1.0",
  "private": true,
  "description": "Drizzle ORM schema, migrations, and queries for internal SQLite database",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@open-query/shared": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.4",
    "@paralleldrive/cuid2": "^2.2.2"
  },
  "devDependencies": {
    "@open-query/config": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3"
  }
}
