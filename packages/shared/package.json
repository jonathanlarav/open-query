{
  "name": "@open-query/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types, constants, and Zod schemas",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@open-query/config": "workspace:*",
    "typescript": "^5.7.3"
  }
}
