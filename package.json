{
  "name": "open-query",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source, self-hostable data exploration tool with natural language SQL generation",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@open-query/db",
    "db:migrate": "turbo run db:migrate --filter=@open-query/db",
    "db:studio": "turbo run db:studio --filter=@open-query/db",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
